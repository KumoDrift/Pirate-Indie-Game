  "meta": {
    "phaserIntegration": {
      "spritesheetLoading": "Use scene.load.spritesheet(key, path, { frameWidth, frameHeight }) for each animation spritesheet. Frame indices are 0-based, laid out left-to-right, top-to-bottom in a grid of columns×rows. Only 'frames' count of cells are valid; remaining cells in the last row are empty.",
      "animationCreation": "Use scene.anims.create({ key, frames: scene.anims.generateFrameNumbers(sheetKey, { start: 0, end: frames - 1 }), frameRate: fps, repeat }). repeat=-1 means loop forever (idle, walk); repeat=0 means play once (attack, hurt, jump, death).",
      "anchorAlignment": "All grounded animations share anchor (128, 255) — the bottom-center of the 256×256 cell. Set sprite origin to (anchor.x / frameWidth, anchor.y / frameHeight) = (0.5, ~1.0) so the sprite's feet align with the world position.",
      "directionFlipping": "All spritesheets face west (left). To face east (right), use sprite.setFlipX(true).",
      "backgroundLoading": "Use scene.load.image(key, path). Backgrounds are 1024×1024 single images — scale or position to fit your game resolution (1280×720)."
    }
